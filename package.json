{
  "name": "fishy-stream",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "concurrently \"convex dev\" \"vite\"",
    "dev:mobile": "concurrently \"convex dev\" \"vite --host 0.0.0.0\"",
    "build": "tsc -b && vite build",
    "build:android": "npm run build && npx cap sync android",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\""
  },
  "dependencies": {
    "@capacitor/android": "8.3.1",
    "@capacitor/cli": "8.3.1",
    "@capacitor/core": "8.3.1",
    "@clerk/react": "6.6.1",
    "@clerk/themes": "2.4.57",
    "@fishyservices/providers": "latest",
    "@fishyservices/ui": "latest",
    "class-variance-authority": "0.7.1",
    "convex": "1.37.0",
    "lucide-react": "1.14.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "7.15.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.2",
    "tailwindcss": "4.2.4",
    "typescript": "~6.0.2",
    "vite": "8.0.11"
  }
}
