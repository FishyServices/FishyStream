{
  "name": "fishy-stream",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"convex dev\" \"vite\"",
    "dev:mobile": "concurrently \"convex dev\" \"vite --host 0.0.0.0\"",
    "build": "tsc -b && vite build",
    "build:android": "npm run build && npx cap sync android",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\""
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@clerk/react": "^6.2.1",
    "@clerk/themes": "^2.4.57",
    "@clerk/types": "^4.101.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "1.36.0",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "@fishy/ui": "git+https://github.com/official-notfishvr/fishy-ui.git"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.8"
  }
}
