{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "types": ["vite/client", "node"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "@/*": ["./src/*"],
      "@fishy/providers": ["./packages/providers/src/index.ts"],
      "@fishy/providers/providerCatalog": ["./packages/providers/src/providerCatalog.ts"],
      "@fishy/providers/providerProxy": ["./packages/providers/src/providerProxy.ts"],
      "@fishy/providers/tvSeasonMappings": ["./packages/providers/src/tvSeasonMappings.ts"],
      "@fishy/providers/anilistResolver": ["./packages/providers/src/anilistResolver.ts"],
      "react": ["./node_modules/@types/react"],
      "react-dom": ["./node_modules/@types/react-dom"]
    },
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "exclude": ["dist", "node_modules"]
}
