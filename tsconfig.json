{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "types": ["vite/client", "@types/bun"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "@/*": ["./src/*"],
      "@content/*": ["./shared/content/*"],
      "@providers/*": ["./packages/providers/src/*"],
      "@fishy/providers": ["./packages/providers/src/index.ts"],
      "@fishy/providers/tmdb": ["./packages/providers/src/tmdb/index.ts"],
      "@fishy/providers/catalog": ["./packages/providers/src/catalog/index.ts"],
      "@fishy/providers/playback": ["./packages/providers/src/playback/index.ts"],
      "@fishy/providers/anime": ["./packages/providers/src/anime/index.ts"],
      "@fishy/providers/proxy": ["./packages/providers/src/proxy/index.ts"],
      "@fishy/providers/*": ["./packages/providers/src/*/index.ts"],
      "@fishy/scraper": ["./packages/scraper/src/index.ts"],
      "react": ["./node_modules/@types/react"],
      "react-dom": ["./node_modules/@types/react-dom"]
    },
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "exclude": ["dist", "node_modules", "packages/scraper/src/dev.ts"]
}
